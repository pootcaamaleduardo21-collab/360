# ══════════════════════════════════════════════════════════════════════════════
# Variables de entorno para Vercel
# Agrega estas en: vercel.com → tu proyecto → Settings → Environment Variables
#
# Vercel maneja 3 entornos independientes:
#   Production  → rama main      → tu dominio de producción
#   Preview     → rama staging   → URL estable de staging (ej. staging.tour360.app)
#   Development → local dev      → igual que .env.local
#
# IMPORTANTE: production y staging deben apuntar a proyectos Supabase distintos
#             para no mezclar datos reales con pruebas.
# ══════════════════════════════════════════════════════════════════════════════

# ── PRODUCTION ────────────────────────────────────────────────────────────────
# Entorno: Production
NEXT_PUBLIC_SUPABASE_URL=https://<project-prod>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...         # anon key del proyecto de producción
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...             # service_role key (¡nunca NEXT_PUBLIC_!)
NEXT_PUBLIC_APP_URL=https://tour360.app           # tu dominio final
NEXT_PUBLIC_SUPER_ADMIN_EMAIL=tu@email.com

# ── STAGING (Preview) ─────────────────────────────────────────────────────────
# Entorno: Preview  →  aplica a la rama "staging" y a cualquier PR
# Usa un proyecto Supabase separado para no contaminar datos de producción.
NEXT_PUBLIC_SUPABASE_URL=https://<project-staging>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...         # anon key del proyecto de staging
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...             # service_role key del proyecto de staging
NEXT_PUBLIC_APP_URL=https://staging.tour360.app   # dominio de staging (opcional)
NEXT_PUBLIC_SUPER_ADMIN_EMAIL=tu@email.com

# ── NOTAS ─────────────────────────────────────────────────────────────────────
# 1. SUPABASE_SERVICE_ROLE_KEY: marca "Sensitive" en Vercel para que no aparezca
#    en logs de build.
# 2. NEXT_PUBLIC_* son embebidas en el bundle del cliente. Nunca pongas secretos
#    con ese prefijo.
# 3. Para crear el proyecto de staging en Supabase:
#    supabase.com → New project → corre el mismo supabase/setup.sql
