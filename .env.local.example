# ── Supabase ─────────────────────────────────────────────────────────────────
# Get these from: https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# Service-role key — NEVER expose this to the browser (no NEXT_PUBLIC_ prefix).
# Used ONLY in server-side API routes (e.g. /api/admin/stats).
# Get it from: Supabase Dashboard → Project Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Super Admin ────────────────────────────────────────────────────────────────
# The email that always receives super_admin role regardless of DB metadata.
# Set this to YOUR email address.
NEXT_PUBLIC_SUPER_ADMIN_EMAIL=tu@email.com

# ── Optional: Cloudinary (alternative CDN) ────────────────────────────────────
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
